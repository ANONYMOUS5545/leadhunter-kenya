# ── Database (Neon PostgreSQL) ───────────────────────────────────────
# Get from: https://neon.tech → your project → connection string
DATABASE_URL="postgresql://username:password@your-neon-host.neon.tech/dbname?sslmode=require"

# ── Auth ─────────────────────────────────────────────────────────────
# Generate a strong random secret: openssl rand -base64 32
JWT_SECRET="your-super-secret-jwt-key-at-least-32-chars"

# ── App ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Stripe (optional - for payment processing) ───────────────────────
# STRIPE_SECRET_KEY="sk_live_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."

# ── SerpAPI (optional - for real Google scraping) ────────────────────
# SERPAPI_KEY="your-serpapi-key"

# ── Apify (optional - for advanced social media scraping) ────────────
# APIFY_TOKEN="your-apify-token"
